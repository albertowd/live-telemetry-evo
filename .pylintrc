[MASTER]
# PySide6 is a C extension; let pylint introspect it instead of bailing on
# every Qt symbol with c-extension-no-member.
extension-pkg-allow-list=PySide6

[TYPECHECK]
# PySide6 Signal objects expose connect/emit/disconnect via runtime metaclass
# magic that pylint cannot statically resolve. Treat any PySide6 attribute
# access as known so bound signal calls do not trigger no-member.
generated-members=PySide6.*

[FORMAT]
max-line-length=180

[BASIC]
# Wheel position labels (FL/FR/RL/RR), single-letter loop vars and the canonical
# logger handle stay readable as-is. dwSize / szExeFile mirror the Win32
# PROCESSENTRY32W field names we have to use verbatim for ctypes binding.
good-names=p,d,e,f,t,n,T,FL,FR,RL,RR,dwSize,szExeFile

[MESSAGES CONTROL]
# - too-few-public-methods: dataclasses + Qt widgets often only override one
#   or two methods; the heuristic produces noise here.
# - too-many-instance-attributes: telemetry data classes legitimately have many
#   fields (one per measurement).
# - too-many-arguments / too-many-positional-arguments: Qt constructors and
#   layout helpers commonly take several positional params.
# - too-many-locals: paintEvent methods aggregate per-frame state.
# - too-many-statements / too-many-branches: the per-game _apply_physics
#   readers are linear field-by-field marshalling against a shared-memory
#   layout; each statement maps to a published field, and grouping them
#   into nested helpers would obscure the wire-format correspondence.
# - duplicate-code: the four shared-memory sources share a connect /
#   reconnect / per-wheel skeleton because the underlying Win32 API is
#   identical — deduplicating across files would hide per-game struct
#   quirks that are easier to reason about side-by-side.
# - protected-access: ``window._tray`` / ``window._detection`` hold owned
#   Qt children solely to anchor their lifetime; the underscore signals
#   intent (don't surface in the public API), not external isolation.
# - chained-comparison: the project mixes attribute accesses on objects
#   that look superficially chainable (``w.susp_m_t``/``w.susp_t``),
#   producing false positives that nesting can't always rewrite away.
# - useless-parent-delegation: ``Power.__init__`` exists to constrain the
#   curve type for callers; removing it would lose the explicit signature.
# - attribute-defined-outside-init: ctypes ``Structure`` subclasses
#   declare fields via ``_fields_`` rather than ``__init__`` — every
#   field assignment trips this otherwise.
# - missing-module-docstring / missing-function-docstring: project favours
#   self-describing names over module/function docstring boilerplate.
# - unused-argument: Qt event handlers receive events we sometimes ignore.
disable=
    too-few-public-methods,
    too-many-instance-attributes,
    too-many-arguments,
    too-many-positional-arguments,
    too-many-locals,
    too-many-statements,
    too-many-branches,
    duplicate-code,
    protected-access,
    chained-comparison,
    useless-parent-delegation,
    attribute-defined-outside-init,
    missing-module-docstring,
    missing-function-docstring,
    unused-argument
